rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Foto de perfil: pública pra leitura (precisa aparecer pros outros
    // jogadores na mesa), mas só o dono pode enviar a própria.
    match /avatares/{uid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
