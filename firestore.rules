rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Jogadores: lê e escreve apenas o próprio perfil
    match /jogadores/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Ranking: leitura pública (leaderboard), escrita só do próprio usuário
    match /ranking/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Transações: só o dono pode ler
    match /transacoes/{txId} {
      allow read: if request.auth != null
                  && request.auth.uid == resource.data.uid;
      allow write: if false; // apenas o backend escreve via Admin SDK
    }

  }
}
